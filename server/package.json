{
  "name": "respawn-server",
  "version": "1.0.0",
  "description": "Zentrales Tool fuer die LAN Party: Matchmaking, Abstimmung, Live-Status, Leaderboard",
  "private": true,
  "type": "commonjs",
  "main": "dist/index.js",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "prepare": "node scripts/setup-git-hooks.js || true",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "jam-controller": "node scripts/jam-controller.mjs",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "test": "tsc -p tsconfig.test.json && cross-env DB_FILE=:memory: node --test \"dist-test/*.test.js\" \"dist-test/arcade/*.test.js\" \"dist-test/test/*.test.js\" && node --test \"public/js/*.test.js\"",
    "test:coverage": "tsc -p tsconfig.test.json && cross-env DB_FILE=:memory: node --test --experimental-test-coverage --test-coverage-exclude=\"dist-test/test/**\" --test-coverage-exclude=\"dist-test/**/*.test.js\" \"dist-test/*.test.js\" \"dist-test/arcade/*.test.js\" \"dist-test/test/*.test.js\"",
    "test:e2e": "npm run build && tsc -p tsconfig.test.json && node --test \"dist-test/test/e2e/*.test.js\"",
    "check:tokens": "node scripts/check-design-tokens.js",
    "lint": "eslint src public/js",
    "format:check": "prettier --check eslint.config.mjs .prettierrc.json ../agent/eslint.config.mjs ../agent/.prettierrc.json"
  },
  "dependencies": {
    "archiver": "^6.0.2",
    "better-sqlite3": "^11.3.0",
    "express": "^4.19.2",
    "helmet": "^8.2.0",
    "nanoid": "^3.3.7",
    "pdfkit": "^0.19.1",
    "qrcode": "^1.5.4",
    "socket.io": "^4.7.5",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/archiver": "^6.0.3",
    "@types/better-sqlite3": "^7.6.11",
    "@types/express": "^4.17.21",
    "@types/node": "^22.5.0",
    "@types/pdfkit": "^0.17.6",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^6.0.2",
    "@types/web-push": "^3.6.4",
    "cross-env": "^7.0.3",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "playwright": "1.56.1",
    "prettier": "^3.9.5",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.0.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.63.0"
  }
}
