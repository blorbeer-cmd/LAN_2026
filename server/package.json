{
  "name": "lan-party-server",
  "version": "1.0.0",
  "description": "Zentrales Tool fuer die LAN Party: Matchmaking, Abstimmung, Live-Status, Leaderboard",
  "private": true,
  "type": "commonjs",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "test": "tsc -p tsconfig.test.json && cross-env DB_FILE=:memory: node --test \"dist-test/*.test.js\" \"dist-test/test/*.test.js\"",
    "test:e2e": "tsc -p tsconfig.test.json && node --test \"dist-test/test/e2e/*.test.js\""
  },
  "dependencies": {
    "archiver": "^6.0.2",
    "better-sqlite3": "^11.3.0",
    "express": "^4.19.2",
    "nanoid": "^3.3.7",
    "qrcode": "^1.5.4",
    "socket.io": "^4.7.5",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.3",
    "@types/better-sqlite3": "^7.6.11",
    "@types/express": "^4.17.21",
    "@types/node": "^22.5.0",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^6.0.2",
    "@types/web-push": "^3.6.4",
    "cross-env": "^7.0.3",
    "playwright": "1.56.1",
    "supertest": "^7.0.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.4"
  }
}
